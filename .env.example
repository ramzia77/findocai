# Copy this file to .env and fill in real values. Never commit .env.
#
# Default provider is Ollama (config.yaml: llm.provider / embedding.provider =
# ollama) -- fully local and free, no key needed here. Just run `ollama serve`
# with `llama3.1:8b` and `nomic-embed-text` pulled. Switch config.yaml to
# openai/azure_openai and fill in the matching keys below to use those instead.

# --- OpenAI (used when llm.provider / embedding.provider = openai) ---
OPENAI_API_KEY=

# --- Azure OpenAI (used when llm.provider / embedding.provider = azure_openai) ---
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# --- API auth ---
# Comma-separated list of API keys accepted by the FastAPI service. Prefer
# key_hash entries in config.yaml (via `python -m scripts.hash_api_key`) for
# anything beyond local dev -- see config.yaml's api.keys comment.
FINDOCAI_API_KEYS=dev-local-key

# --- Environment ---
# Anything other than "local" refuses to start if dev-local-key is the only
# configured API key (see settings.py: is_using_default_credentials).
FINDOCAI_ENV=local

# --- Encryption at rest (optional) ---
# Encrypts audit-log question/answer text and each chunk's raw_text in the
# FAISS metadata sidecar. Unset = no-op (plaintext), the same posture as
# before this feature existed -- not a silent regression, opt-in.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FINDOCAI_ENCRYPTION_KEY=

# --- Observability (optional) ---
SENTRY_DSN=

# --- Database (optional override; default is sqlite:///./findocai.db) ---
DATABASE_URL=
